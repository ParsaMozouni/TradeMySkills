<%- include('partials/header', { title: skill.title }) %>
<section class="container py-4">
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="detail-card p-4 p-lg-5">
        <div class="detail-hero mb-4"><span><%= skill.image %></span></div>
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="chip"><%= skill.category %></span>
          <span class="rating">★ <%= skill.rating %></span>
        </div>
        <h1 class="fw-bold mb-2"><%= skill.title %></h1>
        <p class="text-secondary"><strong><%= skill.owner %></strong> • <%= skill.location %></p>
        <p class="lead"><%= skill.description %></p>
        <div class="row g-3 mt-2">
          <div class="col-md-6">
            <div class="mini-panel">
              <h5>I can offer</h5>
              <p class="mb-0 text-secondary"><%= skill.offer %></p>
            </div>
          </div>
          <div class="col-md-6">
            <div class="mini-panel">
              <h5>I want to learn</h5>
              <p class="mb-0 text-secondary"><%= skill.want %></p>
            </div>
          </div>
        </div>
        <div class="d-flex gap-3 flex-wrap mt-4">
          <a href="/messages" class="btn btn-brand btn-lg">Message user</a>
          <a href="/dashboard" class="btn btn-light border btn-lg">Back to dashboard</a>
        </div>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="detail-card p-4">
        <h4 class="fw-bold mb-3">Related skills</h4>
        <% relatedSkills.forEach(item => { %>
          <a class="related-item" href="/skills/<%= item.id %>">
            <div>
              <strong><%= item.title %></strong>
              <div class="text-secondary small"><%= item.owner %></div>
            </div>
            <span>→</span>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
