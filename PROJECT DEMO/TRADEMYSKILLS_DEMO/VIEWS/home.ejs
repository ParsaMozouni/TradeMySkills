<%- include('partials/header', { title: 'Home' }) %>

<section class="hero-shell">
  <div class="container py-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <p class="eyebrow">Learn. Trade. Grow.</p>
        <h1 class="display-5 fw-bold mb-3">Exchange skills with people who have what you need.</h1>
        <p class="lead text-secondary mb-4">TradeMySkills helps users offer skills, discover learning opportunities, and connect through simple skill-for-skill exchanges.</p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="/register" class="btn btn-brand btn-lg">Get Started</a>
          <a href="/dashboard" class="btn btn-light btn-lg border">Browse Skills</a>
        </div>
        <div class="hero-stats mt-4">
          <div><strong>120+</strong><span> skill listings</span></div>
          <div><strong>45+</strong><span> active users</span></div>
          <div><strong>4.8/5</strong><span> avg rating</span></div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="hero-card shadow-lg">
          <div class="mini-toolbar"></div>
          <div class="row g-3">
            <% featuredSkills.forEach(skill => { %>
              <div class="col-sm-6">
                <div class="skill-card compact-card h-100">
                  <div class="emoji-badge"><%= skill.image %></div>
                  <span class="chip"><%= skill.category %></span>
                  <h5 class="mt-3"><%= skill.title %></h5>
                  <p class="text-secondary small mb-2"><%= skill.owner %></p>
                  <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="rating">★ <%= skill.rating %></span>
                    <a href="/skills/<%= skill.id %>" class="btn btn-brand-sm">View</a>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container py-5">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="info-card h-100">
        <h4>Create a profile</h4>
        <p class="text-secondary mb-0">Users can register and build a profile around the skills they want to offer and learn.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="info-card h-100">
        <h4>Discover matches</h4>
        <p class="text-secondary mb-0">Browse cards, open skill details, and explore other users in a simple dashboard layout.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="info-card h-100">
        <h4>Start a trade</h4>
        <p class="text-secondary mb-0">Use a message-style page to begin discussions and arrange a skill exchange.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
