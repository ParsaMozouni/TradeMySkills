<%- include('partials/header', { title: 'Dashboard' }) %>
<section class="container-fluid py-4 px-4">
  <div class="row g-4">
    <div class="col-xl-2 col-lg-3">
      <div class="sidebar-card sticky-side">
        <h6 class="sidebar-title">Browse</h6>
        <a class="side-link active" href="/dashboard">All Skills</a>
        <a class="side-link" href="#">Technology</a>
        <a class="side-link" href="#">Creative</a>
        <a class="side-link" href="#">Music</a>
        <a class="side-link" href="#">Career</a>
        <a class="side-link" href="#">Health</a>
      </div>
    </div>
    <div class="col-xl-10 col-lg-9">
      <div class="dashboard-shell">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
          <div>
            <p class="eyebrow mb-1">Dashboard</p>
            <h2 class="fw-bold mb-0">Explore available skills</h2>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <input class="form-control search-box" placeholder="Search skills, tags, or users">
            <a href="/skills/new" class="btn btn-brand">+ Post New Skill</a>
          </div>
        </div>
        <div class="row g-4">
          <% skills.forEach(skill => { %>
            <div class="col-md-6 col-xl-4">
              <div class="skill-card h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <div class="emoji-badge"><%= skill.image %></div>
                  <span class="chip"><%= skill.category %></span>
                </div>
                <h4><%= skill.title %></h4>
                <p class="text-secondary mb-2"><%= skill.description %></p>
                <p class="small text-muted mb-3"><strong><%= skill.owner %></strong> • <%= skill.location %></p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                  <% skill.tags.forEach(tag => { %>
                    <span class="tag-pill"><%= tag %></span>
                  <% }) %>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                  <span class="rating">★ <%= skill.rating %></span>
                  <a href="/skills/<%= skill.id %>" class="btn btn-brand-sm">View details</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
